#include<iostream>
#include <vector>
#include <limits>
#include <string>
using namespace std;

class vehicle
{
public:
 string name;
    int wheels;
    int seats;
    float maxSpeed;
    float weight;
    string fuelType;
    
virtual void show() = 0;
    virtual void move() = 0;
    virtual void fuelInfo() = 0;
    virtual void wheelInfo() = 0;
    vehicle(string n,int w,int s,float ms,float wt,string t)
    {
          name=n;
          wheels=w;
          seats=s;
          maxSpeed=ms;
          weight=wt;
          fuelType=t;
    }
 virtual ~vehicle() {}
};

class airplane:public vehicle
{
    public:
    float peakHeight;
    int aviation;
     
    airplane(string n, int w, int s, float ms, float wt, string f)
        : vehicle(n, w, s, ms, wt, f) {}

    void airplaneset(int a, float p) {
        aviation = a;
        peakHeight = p;
    }

    void show() override
    {
        cout << "Airplane: " << name << endl;
        cout << "Seats: " << seats << ", Max Speed: " << maxSpeed << " km/h, Weight: " << weight << " tons" << endl;
        cout << "Peak Height: " << peakHeight << " meters, Aviation Capacity: " << aviation << endl;
    }
    void move() override { cout << name << " is taking off and flying in the sky!" << endl; }
    void fuelInfo() override { cout << name << " runs on " << fuelType << " fuel." << endl; }
    void wheelInfo() override { cout << name << " has " << wheels << " wheels for takeoff and landing." << endl; }
};
class jet:public airplane
{
  public:
    int range;
    bool isSupersonic= true;
    string weapon;
    bool stealthMode;

    jet(string n,int w,int s,float ms,float wt,string t)
    : airplane(n,w,s,ms,wt,t){}

     void jetset(int r,bool s,string w,bool st)
    {
        range = r;
        isSupersonic=s;
        weapon = w;
        stealthMode = st;
    }
    void show() override
    {
        cout << "Jet: " << name << endl;
        cout << "Seats: " << seats << ", Max Speed: " << maxSpeed << " km/h, Weight: " << weight << " tons" << endl;
        cout << "Range: " << range << " km, Weapon: " << weapon << ", Stealth Mode: " << (stealthMode ? "ON" : "OFF") << endl;
    }

    void move() override
    {
        if(isSupersonic) cout << name << " is flying at supersonic speed!" << endl;
        else cout << name << " is cruising normally." << endl;
        if(stealthMode) cout << name << " is in stealth mode..." << endl;
    }

    void fuelInfo() override { cout << name << " runs on " << fuelType << " fuel." << endl; }
    void wheelInfo() override { cout << name << " has " << wheels << " wheels for landing." << endl; }

    bool operator>(jet &other) { return this->range > other.range; }

};
class car:virtual public vehicle
{
   
public:
    string model;
    float speed;
    string color;
    float acceleration;
    void setcar(string m,float s,string c)
    {
        model=m;
        speed=s;
        color=c;
    }
    car(string n,int w,int s,float ms,float wt,string t)
: vehicle(n,w,s,ms,wt,t) {}

    void show() override
    {
        cout << "Car: " << name << endl;
        cout << "Model: " << model << ", Color: " << color << ", Seats: " << seats << endl;
        cout << "Max Speed: " << maxSpeed << " km/h, Acceleration: " << acceleration << " m/s², Weight: " << weight << " tons" << endl;
    }
    void move() override { cout << name << " is driving on the road at " << speed << " km/h!" << endl; }
    void fuelInfo() override { cout << name << " uses " << fuelType << " fuel." << endl; }
    void wheelInfo() override { cout << name << " has " << wheels << " wheels for smooth driving." << endl; }

};
class truck:virtual public vehicle
{
    public:
    float loadcapacity;
    int power;
    string cargotype;
     bool isLoaded=false;
    void settruck(float c,int p,string ct)
    {
       
       loadcapacity=c;
       power=p;
       cargotype=ct;
      
    }truck(string n,int w,int s,float ms,float wt,string t)
 : vehicle(n,w,s,ms,wt,t) {}
     
    void show() override
{
    cout << "Truck Details " << endl;
    cout << "Name: " << name << endl;
    cout << "Wheels: " << wheels << endl;
    cout << "Seats: " << seats << endl;
    cout << "Max Speed: " << maxSpeed << " km/h" << endl;
    cout << "Weight: " << weight << " tons" << endl;
    cout << "Fuel Type: " << fuelType << endl;
    cout << "Load Capacity: " << loadcapacity << " tons" << endl;
    cout << "Power: " << power << " kW" << endl;
    cout << "Cargo Type: " << cargotype << endl;
    cout << (isLoaded ? "Status: Busy, currently loaded\n" : "Status: On a break\n");
}
    void move() override
{
    cout << name << " is moving with " << loadcapacity << " tons load." << endl;
}

void fuelInfo() override
{
    cout << name << " runs on " << fuelType << " fuel." << endl;
}

void wheelInfo() override
{
    cout << name << " has " << wheels << " wheels for carrying heavy loads." << endl;
}

   
};
class BMW: public car
{   
public:
   string series;
    bool isElectric;
     string mode;
    bool launchControl;
BMW(string n,int w,int s,float ms,float wt,string t)
: vehicle(n,w,s,ms,wt,t), car(n,w,s,ms,wt,t) {}
    
   void setBMW(string s,bool e,string m,bool l)
 {
    series =s;
    isElectric=e;
    mode=m;
    launchControl=l;
 }
    void show() override
    {
        cout << "BMW: " << name << endl;
        cout << "Series: " << series << ", Electric: " << (isElectric ? "Yes" : "No") << ", Mode: " << mode << endl;
        cout << "Max Speed: " << maxSpeed << " km/h, Acceleration: " << acceleration << " m/s²" << endl;
        cout << "Seats: " << seats << ", Color: " << color << ", Weight: " << weight << " tons" << endl;
    }

    void move() override
    {
        cout << name << " is moving " << (isElectric ? "silently (electric)" : "on fuel") << " in " << mode << " mode." << endl;
        if(launchControl) cout << "Launch control engaged! 🚀" << endl;
    }

    void fuelInfo() override { cout << name << " uses " << fuelType << " fuel." << endl; }
    void wheelInfo() override { cout << name << " has " << wheels << " wheels." << endl; }
    void pace(int s)
    {
       cout<<"She scales as high as "<<s<<"!!"<<endl;
    }
    void pace(float d,float t)
    {
        float rs= d/t;
      cout<<"You said she ran "<<d<<" km in "<< t<< "hours...told ya she is  quick.like this time she ran at "<<rs<<" kmph"<<endl;
    }
    
};
