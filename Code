void getInput(string &name, int &wheels, int &seats, float &maxspeed, float &weight, string &fuelType)
{
    cout << "Name:" << endl;
    getline(cin, name);

    cout << "Wheels:" << endl;
    cin >> wheels;

    cout << "Seats:" << endl;
    cin >> seats;

    cout << "Maxspeed:" << endl;
    cin >> maxspeed;

    cout << "Weight:" << endl;
    cin >> weight;
    cin.ignore(numeric_limits<streamsize>::max(), '\n'); // clear buffer before next getline

    cout << "Fuel Type:" << endl;
    getline(cin, fuelType);
}

int main()
{
    vector <vehicle*> garage;
    int n;
    cout << "Number of vehicles:" << endl;
    cin >> n;
    cin.ignore(numeric_limits<streamsize>::max(), '\n'); // clear buffer

    for(int i = 0; i < n; i++)
    {
        string choice;
        cout << "Choice (airplane / jet / car /truck /BMW /Ferrari /Lamborghini):" << endl;
        getline(cin, choice);

        string name;
        int wheels;
        int seats;
        float maxspeed;
        float weight;
        string fuelType;

        getInput(name, wheels, seats, maxspeed, weight, fuelType);

        if(choice == "airplane")
        {
            float peakHeight;
            int aviation;
            cout << "Enter peak height:" << endl; 
            cin >> peakHeight;
            cout << "Enter aviation capacity:" << endl; 
            cin >> aviation;
            cin.ignore(numeric_limits<streamsize>::max(), '\n'); // clear buffer

            airplane *A = new airplane(name, wheels, seats, maxspeed, weight, fuelType);
            A->airplaneset(aviation, peakHeight);
            garage.push_back(A);
        }
        else if(choice == "jet")
        {
            int range;
            bool isSupersonic;
            string weapon;
            bool stealthMode;

            cout << "Enter range:" << endl; 
            cin >> range;
            cout << "Is it supersonic? (1/0):" << endl; 
            cin >> isSupersonic;
            cin.ignore(numeric_limits<streamsize>::max(), '\n'); // clear buffer

            cout << "Enter weapon:" << endl; 
            getline(cin, weapon);

            cout << "Does it support stealth mode? (1/0):" << endl; 
            cin >> stealthMode;
            cin.ignore(numeric_limits<streamsize>::max(), '\n'); // clear buffer

            jet *B = new jet(name, wheels, seats, maxspeed, weight, fuelType);
            B->jetset(range, isSupersonic, weapon, stealthMode);
            garage.push_back(B);
        }
        else if(choice == "car")
        {
            string model;
            float speed;
            string color;

            cout << "Enter model:" << endl; 
            getline(cin, model);

            cout << "Enter speed:" << endl; 
            cin >> speed;
            cin.ignore(numeric_limits<streamsize>::max(), '\n'); // clear buffer

            cout << "Enter color:" << endl; 
            getline(cin, color);

            car *C = new car(name, wheels, seats, maxspeed, weight, fuelType);
            C->setcar(model, speed, color);
            garage.push_back(C);
        }

        else if(choice=="truck")
        {
            float loadcapacity;
            int power;
            string cargotype;

            cout<<"Enter load capacity:"<<endl;
            cin>>loadcapacity;

            cout<<"Enter power:"<<endl;
            cin>>power;
            cin.ignore(numeric_limits<streamsize>::max(), '\n');

            cout<<"Enter cargotype:"<<endl;
            getline(cin,cargotype);

            truck *D = new truck(name, wheels, seats, maxspeed, weight, fuelType);
            D->settruck(loadcapacity,power,cargotype);
            garage.push_back(D);
        }

        else if(choice=="BMW")
        {
            string series;
            bool isElectric;
            string mode;
            bool launchControl;
            int acceleration;

            cout<<"Enter series:"<<endl;
            getline(cin,series);

            cout<<"Is it electric (0/1)??"<<endl;
            cin>>isElectric;
            cin.ignore(numeric_limits<streamsize>::max(), '\n');

            cout<<"Enter mode"<<endl;
            getline(cin,mode);

            cout<<"Does it have launch control (0/1) ??"<<endl;
            cin>>launchControl;

            cout<<"Enter acceleration:";
            cin>>acceleration;
            cin.ignore(numeric_limits<streamsize>::max(), '\n');

            BMW *E = new BMW(name, wheels, seats, maxspeed, weight, fuelType);
            E->setBMW(series,isElectric,mode,launchControl);
            E->pace(acceleration);
            garage.push_back(E);
        }

        else if(choice=="Ferrari")
        {
            string Ferrarimodel;        // F8, SF90, 488
            string series;       // GTB, Spider
            float topSpeed;
            bool hasF1Gearbox;

            cout<<"Enter model:"<<endl;
            getline(cin,Ferrarimodel);

            cout<<"Enter series:"<<endl;
            getline(cin,series);

            cout<<"Top speed:"<<endl;
            cin>>topSpeed;

            cout<<"Does it have F1 Gear box (0/1)?"<<endl;
            cin>>hasF1Gearbox;
            cin.ignore(numeric_limits<streamsize>::max(), '\n');

            Ferrari *F = new Ferrari(name, wheels, seats, maxspeed, weight, fuelType);
            F->setFerrari(Ferrarimodel,series,topSpeed,hasF1Gearbox);
            garage.push_back(F);
        }

        else if(choice== "Lamborghini")
        {
            string lambomodel;        // Aventador, Huracan
            string edition; 
            bool isAWD;     // SVJ, Performante
            string driveMode;
            bool scissorDoors;

            cout<<"Enter model:"<<endl;
            getline(cin,lambomodel);

            cout<<"Enter edition:"<<endl;
            getline(cin,edition);

            cout<<"Is it AWD (0/1)?"<<endl;
            cin>>isAWD;
            cin.ignore(numeric_limits<streamsize>::max(), '\n');

            cout<<"Enter Drive mode:"<<endl;
            getline(cin,driveMode);

            cout<<"Does it have scissor door (0/1)?"<<endl;
            cin>>scissorDoors;
            cin.ignore(numeric_limits<streamsize>::max(), '\n');

            Lamborghini *G = new Lamborghini(name, wheels, seats, maxspeed, weight, fuelType);
            G->setLambo(lambomodel,edition,isAWD,driveMode,scissorDoors);
            garage.push_back(G);
        }

        cout << "Showing vehicles so far:" << endl;
        for(auto val : garage)
        {
            val->show();
            val->move();
            val->fuelInfo();
            val->wheelInfo();
        }
        cout << "---------------------------" << endl;
    }

    for(auto v : garage) delete v;
    garage.clear();
    return 0;
}    

